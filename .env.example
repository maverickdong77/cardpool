# LINE Bot 設定
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 網站設定
BASE_URL=https://your-domain.com

# 後台管理員 LINE User ID（新訂單成交時推播通知用）
ADMIN_LINE_USER_ID=

# 保護殼加購價格（新台幣，預設 50）
# PROTECTIVE_CASE_PRICE_TWD=50

# ── Email 通知（SendGrid）──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# 管理員收信地址（預設 teemo901212@gmail.com）
ADMIN_NOTIFY_EMAIL=teemo901212@gmail.com

# ── Google OAuth2 ──
# 從 Google Cloud Console → API & Services → Credentials 建立 OAuth2 用戶端
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 本站公開域名（OAuth callback 用）
API_PUBLIC_BASE=https://your-domain.com
# 登入成功後帶 token 重定向到前端的 base URL
FRONTEND_BASE_URL=https://your-frontend.com/
