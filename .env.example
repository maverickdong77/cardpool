# LINE Bot 設定
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 網站設定
BASE_URL=https://your-domain.com

# 後台管理員 LINE User ID（新訂單成交時推播通知用）
# 從 LINE Developers Console 或 Webhook 事件 source.userId 取得
ADMIN_LINE_USER_ID=

# 賣家上架 — 保護殼加購價格（新台幣，預設 50）
# PROTECTIVE_CASE_PRICE_TWD=50
